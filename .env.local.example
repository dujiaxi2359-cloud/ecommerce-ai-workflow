OPENAI_API_KEY=sk-your-api-key
OPENAI_IMAGE_MODEL=gpt-image-2

# Optional: Azure OpenAI SDK-style config. When present, image generation uses Azure first.
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-key
OPENAI_API_VERSION=2025-04-01-preview
DEPLOYMENT_NAME=gpt-image-2

# Optional: override local DNS for api.openai.com when DNS is polluted.
OPENAI_DNS_OVERRIDE=104.18.7.192,104.18.6.192

# Optional: use only when you route OpenAI through a compatible proxy/gateway.
# OPENAI_BASE_URL=https://api.openai.com/v1
